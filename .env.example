# LiteLLM edition - paste ONE provider key below (uncomment the line).
# OpenAI:
# OPENAI_API_KEY=sk-...
# Anthropic:
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: force a specific model (any LiteLLM id). If unset, it auto-picks
# gpt-4o-mini (OpenAI key present) or anthropic/claude-sonnet-5 (Anthropic key).
# WORKSHOP_MODEL=gpt-4o-mini
